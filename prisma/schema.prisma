generator client {
  provider = "prisma-client-js"
}

// Puedes cambiar "mysql" por "postgresql" dependiendo de tu servidor
datasource db {
  provider = "mysql"
}

// Enum para manejar los distintos tipos de usuarios en la plataforma
enum Role {
  PATIENT
  PSYCHOLOGIST
  PARENT
  ADMIN
}

model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique
  password       String
  name           String
  role           Role           @default(PATIENT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relaciones
  journalEntries JournalEntry[]
  appointments   Appointment[]
  
  // Nuevas relaciones para el Dashboard
  moods          Mood[]
  activities     Activity[]
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text // Lo que escribe el paciente
  aiSummary String?  @db.Text // El resumen o análisis que devolverá Gemini
  sentiment String?           // Ej. "Ansiedad", "Depresión", "Estable"
  createdAt DateTime @default(now())
  
  // Relación con el usuario (Paciente)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Appointment {
  id             Int      @id @default(autoincrement())
  date           DateTime
  status         String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  isOnline       Boolean  @default(true)
  
  // Relación con los usuarios involucrados
  patientId      Int
  psychologistId Int
  
  patient        User     @relation(fields: [patientId], references: [id])
  // En Prisma, cuando hay múltiples relaciones al mismo modelo (User), 
  // se deben nombrar explícitamente, pero lo dejaremos simple por ahora.
}

// Tabla para el Bloque 2: Estado de Ánimo
model Mood {
  id        Int      @id @default(autoincrement())
  userId    Int
  state     String   // "Tranquilo", "Ansioso", "Feliz", etc.
  createdAt DateTime @default(now()) // Guarda la fecha y hora exacta
  
  // Relación con el usuario
  user      User     @relation(fields: [userId], references: [id])
}

// Tabla para el Bloque 3: Actividades
model Activity {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String   // "Diario de Gratitud", "Meditación de respiración"
  duration    Int?     // Tiempo en minutos (opcional)
  isCompleted Boolean  @default(false) // Empieza como NO completada (gris)
  date        DateTime @default(now()) // Para saber qué día se hizo
  
  // Relación con el usuario
  user        User     @relation(fields: [userId], references: [id])
}